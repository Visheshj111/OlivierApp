{
  "name": "olivier",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Olivier – Desktop lead manager with native notifications and system tray",
  "author": "vishe",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"node electron/start-electron.cjs\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:publish": "vite build && electron-builder --win --publish always",
    "electron:pack": "vite build && electron-builder --dir"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.olivier.app",
    "productName": "Olivier",
    "asar": false,
    "directories": {
      "output": "C:/temp/olivier-build"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/icon.png",
      "electron/tray-icon.png",
      "package.json"
    ],
    "icon": "build/icon.ico",
    "extraResources": [],
    "publish": [
      {
        "provider": "github",
        "owner": "Visheshj111",
        "repo": "OlivierApp"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Olivier"
    },
    "portable": {
      "artifactName": "Olivier-Portable.exe"
    }
  }
}
